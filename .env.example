ASYNC_DATABASE_URL=postgresql+asyncpg://dispatch:dispatch@localhost:5432/dispatch
# 兼容旧键名（若设置了 ASYNC_DATABASE_URL，可删除此行）
DATABASE_URL=postgresql+asyncpg://dispatch:dispatch@localhost:5432/dispatch
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# mail（开发环境可先用默认；生产环境请改成真实值）
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
